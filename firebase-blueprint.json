{
  "entities": {
    "product": {
      "title": "Product",
      "description": "Sushi or other food items in the catalog",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "description": { "type": "string" },
        "price": { "type": "number" },
        "image": { "type": "string" },
        "category": { "type": "string" },
        "available": { "type": "boolean" }
      },
      "required": ["name", "price", "image"]
    },
    "deliveryZone": {
      "title": "Delivery Zone",
      "description": "Neighborhoods and their respective shipping fees",
      "type": "object",
      "properties": {
        "name": { "type": "string" },
        "price": { "type": "number" }
      },
      "required": ["name", "price"]
    },
    "order": {
      "title": "Order",
      "description": "Customer orders",
      "type": "object",
      "properties": {
        "customerName": { "type": "string" },
        "phone": { "type": "string" },
        "address": { "type": "string" },
        "neighborId": { "type": "string" },
        "total": { "type": "number" },
        "deliveryFee": { "type": "number" },
        "createdAt": { "type": "string", "format": "date-time" }
      }
    }
  },
  "firestore": {
    "/products/{productId}": {
      "schema": "product",
      "description": "Menu items"
    },
    "/deliveryZones/{zoneId}": {
      "schema": "deliveryZone",
      "description": "Shipping regions"
    },
    "/orders/{orderId}": {
      "schema": "order",
      "description": "Client orders history"
    }
  }
}
